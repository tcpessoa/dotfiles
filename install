#!/usr/bin/env bash
# Single entrypoint for provisioning a machine from this repo.
# Order matters: bootstrap installs prerequisites (incl. brew), packages installs the
# CLI tools (incl. `stow` itself), and only then can sync-stow create the symlinks.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "==> [1/3] bootstrap"
"$SCRIPT_DIR/setup/bootstrap"

echo "==> [2/3] packages"
"$SCRIPT_DIR/packages/install"

echo "==> [3/3] stow"
"$SCRIPT_DIR/setup/sync-stow"

echo "✅ Done. Restart your terminal for all changes to take effect."
