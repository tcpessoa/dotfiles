#!/usr/bin/env bash
# review-changes - Show changes across git repos for a date or range

show_unstaged=false
show_stat=false
since=$(date +%Y-%m-%d)
until=$(date +%Y-%m-%d)
# Author resolved per-repo by default (handles multi-identity setups via includeIf).
# Override with positional arg: `review-changes 2025-01-29 'email@example.com'`.
author_override=""

while [[ "$#" -gt 0 ]]; do
    case $1 in
        -u|--unstaged) show_unstaged=true; shift ;;
        -y|--yesterday) since=$(date -v-1d +%Y-%m-%d); until=$since; shift ;;
        -d|--days)
            if ! [[ $2 =~ ^[0-9]+$ ]]; then
                echo "Error: -d requires a number" >&2; exit 1
            fi
            since=$(date -v-${2}d +%Y-%m-%d); shift 2 ;;
        --since) since=$2; shift 2 ;;
        --until) until=$2; shift 2 ;;
        --stat) show_stat=true; shift ;;
        -h|--help)
            echo "Usage: review-changes [options] [date] [author]"
            echo "Options:"
            echo "  -u, --unstaged    Include unstaged changes"
            echo "  -y, --yesterday   Show yesterday's commits"
            echo "  -d, --days N      Show commits from the last N days"
            echo "      --since DATE  Start of range (YYYY-MM-DD)"
            echo "      --until DATE  End of range (YYYY-MM-DD)"
            echo "      --stat        Include per-commit diff stats"
            echo "  -h, --help        Show this help message"
            echo ""
            echo "Examples:"
            echo "  review-changes                              # Today's commits"
            echo "  review-changes -y                           # Yesterday's commits"
            echo "  review-changes -d 7                         # Last 7 days"
            echo "  review-changes --since 2025-01-01 --until 2025-01-31"
            echo "  review-changes -u                           # Include unstaged"
            echo "  review-changes --stat                       # Show diff stats"
            echo "  review-changes 2024-01-29                   # Specific date"
            echo "  review-changes 2025-01-29 'Tiago Pessoa'    # By specific author"
            exit 0
            ;;
        *)
            if [[ $1 =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
                since=$1; until=$1
            else
                author_override=$1
            fi
            shift ;;
    esac
done

found_changes=false

author_label="${author_override:-per-repo identity}"
if [[ "$since" == "$until" ]]; then
    echo "🔍 Reviewing changes for $since by $author_label"
else
    echo "🔍 Reviewing changes from $since to $until by $author_label"
fi
echo "----------------------------------------"

is_git_repo() {
    git -C "$1" rev-parse --is-inside-work-tree &>/dev/null
}

review_repo() {
    local repo_path="$1"
    local repo_name=$(basename "$repo_path")

    local repo_author="${author_override:-$(git -C "$repo_path" config user.email 2>/dev/null)}"
    [[ -z "$repo_author" ]] && return  # repo with no identity configured — skip

    local log_args=(
        --since="$since 00:00:00"
        --until="$until 23:59:59"
        --author="$repo_author"
        --oneline
    )
    if $show_stat; then
        log_args+=(--shortstat)
    fi

    local commits
    commits=$(git -C "$repo_path" log "${log_args[@]}" 2>/dev/null)

    local unstaged=""
    if $show_unstaged; then
        unstaged=$(git -C "$repo_path" status --porcelain 2>/dev/null)
    fi

    if [[ -n "$commits" || ($show_unstaged && -n "$unstaged") ]]; then
        found_changes=true
        echo "📁 $repo_name:"
        echo "    ($repo_path)"

        if [[ -n "$commits" ]]; then
            echo "  Commits:"
            echo "$commits" | sed 's/^/    /'
        fi

        if $show_unstaged && [[ -n "$unstaged" ]]; then
            echo "  Unstaged changes:"
            echo "$unstaged" | sed 's/^/    /'
        fi
        echo
    fi
}

current_dir=$(pwd)

for dir in \
    "$HOME/dotfiles" \
    "$HOME/.config/nvim" \
    "$HOME/Documents/repos_work/"*/ \
    "$HOME/code/"*/; do
    if [[ -d "$dir" ]] && is_git_repo "$dir"; then
        review_repo "$dir"
    fi
done

# Also check current directory if it's a git repo and not already covered
if [[ "$current_dir" != "$HOME/dotfiles" ]] && \
   [[ "$current_dir" != "$HOME/.config/nvim" ]] && \
   [[ ! "$current_dir" =~ ^$HOME/Documents/repos_work/ ]] && \
   [[ ! "$current_dir" =~ ^$HOME/code/ ]] && \
   is_git_repo "$current_dir"; then
    review_repo "$current_dir"
fi

if ! $found_changes; then
    if [[ "$since" == "$until" ]]; then
        echo "No changes found for $since"
    else
        echo "No changes found from $since to $until"
    fi
fi
