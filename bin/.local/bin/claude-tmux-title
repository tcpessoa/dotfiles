#!/usr/bin/env bash
# Drive the tmux window name from Claude Code hook events.
#
#   claude-tmux-title working   # UserPromptSubmit: name window after the prompt  -> "▶ ..."
#   claude-tmux-title done       # Stop: mark window finished (awaiting user)      -> "✓ ..."
#   claude-tmux-title notify     # Notification: needs your input / permission      -> "⏸ ..."
#
# Reads the hook's JSON payload on stdin. No-ops cleanly when not inside tmux.
# Prints nothing to stdout (UserPromptSubmit would otherwise inject it as context).

mode="$1"
max=24   # keep tabs short; longer titles get an ellipsis

# Always drain stdin so Claude's hook pipe never blocks.
input="$(cat)"

# Outside tmux there's nothing to rename.
[ -z "$TMUX" ] && exit 0

# Strip any leading status glyph this script may have added previously.
strip_glyph() {
  local s="$1" g
  for g in "▶ " "✓ " "⏸ "; do s="${s#"$g"}"; done
  printf '%s' "$s"
}

# Record agent state + its tab color as per-window options so the theme can color the tab.
set_state() {
  local color=""
  case "$1" in
    running) color="#E6C384" ;;  # yellow — working
    paused)  color="#E46876" ;;  # red    — needs you
    done)    color="#98BB6C" ;;  # green  — your turn
  esac
  tmux set-option -w -t "$TMUX_PANE" @agent "$1" 2>/dev/null
  tmux set-option -w -t "$TMUX_PANE" @agent_color "$color" 2>/dev/null
}

# Re-label the current window, preserving the existing text after the glyph.
relabel() {
  local glyph="$1" state="$2" cur
  cur="$(tmux display-message -p -t "$TMUX_PANE" '#W' 2>/dev/null)"
  tmux rename-window -t "$TMUX_PANE" "${glyph} $(strip_glyph "$cur")" 2>/dev/null
  set_state "$state"
}

case "$mode" in
  working)
    prompt="$(printf '%s' "$input" | jq -r '.prompt // empty' 2>/dev/null)"
    [ -z "$prompt" ] && exit 0
    title="$(printf '%s' "$prompt" | tr '\n\t' '  ' | tr -s ' ' | sed 's/^ *//; s/ *$//')"
    if [ "${#title}" -gt "$max" ]; then
      title="$(printf '%s' "$title" | cut -c1-"$max" | sed 's/ *$//')…"
    fi
    tmux rename-window -t "$TMUX_PANE" "▶ $title" 2>/dev/null
    set_state running
    ;;
  run)
    # a tool just executed -> back to running (re-toggles ⏸ after a permission is approved)
    relabel "▶" running
    ;;
  done)
    relabel "✓" done
    ;;
  notify)
    relabel "⏸" paused
    ;;
  clear)
    # session ended -> drop state so the cross-session roll-up stops counting it,
    # and let tmux auto-name the window again.
    tmux set-option -uw -t "$TMUX_PANE" @agent 2>/dev/null
    tmux set-option -uw -t "$TMUX_PANE" @agent_color 2>/dev/null
    tmux set-window-option -t "$TMUX_PANE" automatic-rename on 2>/dev/null
    ;;
esac

exit 0
